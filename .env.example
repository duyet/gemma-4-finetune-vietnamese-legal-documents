# Environment Configuration for Gemma 4 Vietnamese Legal Documents
# Copy this file to .env and fill in your values

# ============================================
# Git Repository Configuration
# ============================================
GITHUB_REPO="git@github.com:duyet/gemma-4-finetune-vietnamese-legal-documents.git"
GITHUB_USERNAME="duyet"

# HuggingFace Configuration
HF_USERNAME="duyet"
HF_REPO_NAME="gemma-4-finetune-vietnamese-legal-documents"

# HuggingFace Access Token (Optional - can also use `huggingface-cli login`)
# Get your token from: https://huggingface.co/settings/tokens
# Required permissions: Write (for creating repos and uploading)
# Format: hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HF_TOKEN=""  # Uncomment and set your token here, OR use Colab secrets

# ============================================
# HuggingFace Repository Names
# ============================================
HF_DATASET_NAME="vietnamese-legal-documents"
HF_MODEL_NAME="gemma-4-vietnamese-legal-rag"

# ============================================
# Crawler Configuration
# ============================================
CRAWLER_MAX_PAGES=100
CRAWLER_DELAY=2.5
CRAWLER_CONCURRENT_REQUESTS=4

# ============================================
# Training Configuration
# ============================================
MAX_SEQ_LENGTH=4096
BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=4
LEARNING_RATE=2e-4
NUM_EPOCHS=1

# ============================================
# Model Configuration
# ============================================
BASE_MODEL="unsloth/gemma-4-E2B-it"
LORA_R=16
LORA_ALPHA=16
LORA_DROPOUT=0.05

# ============================================
# RAG Configuration
# ============================================
EMBEDDING_MODEL="bkai-foundation-models/vietnamese-bi-encoder"
VECTOR_STORE_PATH="./data/chroma_db"
TOP_K_RETRIEVAL=3

# ============================================
# Paths
# ============================================
DATA_DIR="./data"
RAW_DATA_DIR="./data/raw"
PROCESSED_DATA_DIR="./data/processed"
PRETRAIN_DIR="./data/pretrain"
SFT_DIR="./data/sft"
